# 你的真实 Polymarket API 密钥
API_KEY=your-real-api-key-here
API_SECRET=your-api-secret-here

# 初始配置：小额测试
SERIES_SLUG=btc-up-or-down-5m
LEVELS_EACH_SIDE=3
GRID_STEP=0.01
ORDER_SIZE=1.0
TRADE_BOTH_OUTCOMES=false

# 严格的风险管理
DAILY_LOSS_LIMIT=100
MAX_POSITION_SIZE=500
DRY_RUN=false

POLLING_INTERVAL=5000
VERBOSE=true

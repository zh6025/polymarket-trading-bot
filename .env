# Polymarket Trading Bot Configuration

# API Configuration (optional for read-only operations)
API_KEY=demo-key

# Market Parameters
SERIES_SLUG=btc-up-or-down-5m

# Grid Trading Parameters
LEVELS_EACH_SIDE=5
GRID_STEP=0.02
ORDER_SIZE=5
TRADE_BOTH_OUTCOMES=true

# Risk Management
DAILY_LOSS_LIMIT=1000
MAX_POSITION_SIZE=5000

# Running Parameters
DRY_RUN=true
POLLING_INTERVAL=60000
VERBOSE=true

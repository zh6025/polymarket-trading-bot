# ============================================
# Polymarket Trading Bot - 完整配置说明
# 复制此文件为 .env 并填入真实值
# ============================================

# ---- Polymarket API ----
# 你的 Polymarket CLOB API Key
# 获取方式：登录 https://polymarket.com → 账户设置 → API Keys
API_KEY=your_polymarket_api_key_here

# ---- 实盘交易凭证（TRADING_ENABLED=true 且 DRY_RUN=false 时必填）----
# CLOB 主机地址（一般无需修改）
CLOB_HOST=https://clob.polymarket.com
# Polygon 主网 chain id
CHAIN_ID=137
# 用于签名订单的 EOA 私钥（0x 开头，64 位 hex）
PRIVATE_KEY=
# 资金钱包地址（注意不是 EOA 地址）：
#   SIGNATURE_TYPE=0 (EOA)              → 留空 / 填 EOA 地址
#   SIGNATURE_TYPE=1 (POLY_PROXY)       → 填 Polymarket Proxy 地址（邮箱/Magic 登录）
#   SIGNATURE_TYPE=2 (POLY_GNOSIS_SAFE) → 填 Gnosis Safe 地址（MetaMask 登录）
FUNDER=
# 0=EOA, 1=POLY_PROXY, 2=POLY_GNOSIS_SAFE
SIGNATURE_TYPE=1
# 可选：直接提供 L2 API creds；留空则首次启动自动派生（推荐）
CLOB_API_KEY=
CLOB_API_SECRET=
CLOB_API_PASSPHRASE=


# ---- 策略配置 ----
# 交易市场 slug（机器人会动态查找最新 BTC 5分钟市场，此配置作为查找基准）
SERIES_SLUG=btc-up-or-down-5m

# 策略类型（imbalance | grid | sniper）
STRATEGY=imbalance

# 网格每侧挂单层数（默认 5 层）
LEVELS_EACH_SIDE=5

# 网格步长，价格间距（默认 0.02 = 2%）
GRID_STEP=0.02

# 每笔订单大小（单位 USDC，默认 5）
ORDER_SIZE=5

# 是否同时交易 UP 和 DOWN 两个方向（true=双向）
TRADE_BOTH_OUTCOMES=true

# ---- 安全开关 ----
# ⚠️ 必须显式设为 true 才能真实交易，默认 false（监控模式）
# 注意：python-dotenv 会把 `KEY=value#注释` 整串读成 value，导致解析失败！
# 所以行内注释前一定要留空格：`TRADING_ENABLED=true  # 注释`，或者把注释独立放到上一行。
TRADING_ENABLED=false

# 模拟模式：true=模拟（不会真实下单），false=实盘
# ⚠️ 上线前务必先用 true 验证策略，确认无误后改为 false
DRY_RUN=true

# ---- 方向评分器（DirectionScorer）配置 ----
# 是否启用9维度评分器（false=回退到简单mid-price比率）
SCORER_ENABLED=true

# Sigmoid 陡峭度（值越大对信号越敏感，默认 3.0）
SCORER_STEEPNESS=3.0

# 买多门槛（prob_up > 此值时方向=BUY_YES，默认 0.58）
SCORER_BUY_THRESHOLD=0.58

# 卖空门槛（prob_up < 此值时方向=BUY_NO，默认 0.42）
SCORER_SELL_THRESHOLD=0.42

# 最低置信度（|prob_up - 0.5| * 2 < 此值时跳过，默认 0.15）
MIN_CONFIDENCE=0.15

# ---- 价格窗口配置 ----
# 主仓价格区间（效率最高区间，默认 0.50~0.65）
MAIN_PRICE_MIN=0.50
MAIN_PRICE_MAX=0.65

# 对冲价格区间（越低越好，默认 0.05~0.15）
HEDGE_PRICE_MIN=0.05
HEDGE_PRICE_MAX=0.15

# ---- 对冲配置 ----
# 是否先挂对冲单（true=先对冲后主仓，默认 true）
HEDGE_FIRST=true

# Polymarket 手续费率（默认 2%）
FEE_RATE=0.02

# ---- 风控配置 ----
# 每日最大亏损上限（USDC，超过后触发熔断，默认 20）
DAILY_LOSS_LIMIT_USDC=20

# 每日最大交易次数（默认 20；设为 0 或负数表示不限）
DAILY_TRADE_LIMIT=20

# 连续亏损上限（超过后停止，默认 3）
CONSECUTIVE_LOSS_LIMIT=3

# 旧风控参数（保留兼容性）
DAILY_LOSS_LIMIT=100
MAX_POSITION_SIZE=500

# ---- 时间窗口配置（秒）----
# 硬停时间：距到期不足此秒数不入场（默认 30）
HARD_STOP_SEC=30

# 主仓最小剩余时间（默认 90 秒）
MIN_SECS_MAIN=90

# 对冲最小剩余时间（默认 60 秒）
MIN_SECS_HEDGE=60

# ---- 市场质量配置 ----
# 最大允许 Spread（默认 0.05 = 5%）
MAX_SPREAD=0.05

# 最小市场深度（USDC，默认 50）
MIN_DEPTH=50

# ---- 下注规模 ----
# 每次主仓下注大小（USDC，默认 3.0）
BET_SIZE_USDC=3.0

# ---- 运行配置 ----
# 轮询间隔（毫秒，默认 60000 = 60秒）
POLLING_INTERVAL=60000

# ---- 日志 ----
LOG_LEVEL=info

# ---- 末端狙击策略配置（STRATEGY=sniper 时生效）----
# 入场时间：在窗口结束前N秒触发评估（默认 30）
SNIPER_ENTRY_SECS=30

# 份额价格区间（低于此区间说明市场太确定；高于则赔率不划算）
SNIPER_PRICE_MIN=0.55
SNIPER_PRICE_MAX=0.60

# BTC最小偏离（基点，1bps=0.01%，默认 2.0）
SNIPER_MIN_DELTA_BPS=2.0

# 动量确认时间窗（秒，默认 30）
SNIPER_MOMENTUM_SECS=30

# Kelly系数缩放因子（0.5=半Kelly，默认 0.5）
SNIPER_KELLY_FRACTION=0.5
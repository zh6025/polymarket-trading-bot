# ============================================
# Polymarket Trading Bot - 完整配置说明
# 复制此文件为 .env 并填入真实值
# ============================================

# ---- Polymarket API ----
# 你的 Polymarket CLOB API Key
# 获取方式：登录 https://polymarket.com → 账户设置 → API Keys
API_KEY=your_polymarket_api_key_here

# ---- 策略配置 ----
# 交易市场 slug 现在由机器人动态计算（btc-updown-5m-<epoch时间戳>），无需手动配置
# SERIES_SLUG 已废弃，保留仅供参考
# SERIES_SLUG=btc-updown-5m-<timestamp>

# ---- 晚期失衡策略参数 ----

# 市场开启后多少秒内不入场（避免早期随机波动）
# 默认 90 秒
ENTRY_DELAY_SECONDS=90

# 市场开启后多少秒后不再入场（确保有足够时间结算）
# 默认 270 秒（5分钟市场的最后 30 秒不入场）
TRADE_WINDOW_END_SECONDS=270

# 判断某一方主导的隐含价格阈值（例如 0.68 表示该方合约价 ≥ 0.68 才视为主导）
# 默认 0.68
DOMINANCE_THRESHOLD=0.68

# 允许的最大点差百分比（超过则跳过交易，避免流动性差的市场）
# 默认 0.05（即 5%）
MAX_SPREAD_PCT=0.05

# 信号生成所需最少价格样本数
# 默认 5
MIN_SAMPLES=5

# 触发入场前，失衡信号需连续确认的次数
# 默认 2（即连续 2 次检查都显示同一方主导才入场）
CONFIRMATION_CHECKS=2

# 主力方向单笔买入的名义规模（USDC）
# 默认 5.0
MAIN_NOTIONAL=5.0

# ---- 可选对冲参数 ----

# 是否启用弱势方极端反转对冲买入（默认关闭）
# 仅在弱势方价格极低时才会触发（见 HEDGE_MAX_PRICE）
ENABLE_HEDGE=false

# 对冲买入的名义规模（USDC），应远小于主力规模
# 默认 1.0
HEDGE_NOTIONAL=1.0

# 弱势方价格上限：仅当弱势方价格 ≤ 此值时才允许对冲
# 默认 0.15（即弱势方隐含概率 ≤ 15%）
HEDGE_MAX_PRICE=0.15

# ---- 风控配置 ----
# 每日最大亏损上限（USDC，超过后停止交易）
DAILY_LOSS_LIMIT=100

# 最大持仓规模（USDC）
MAX_POSITION_SIZE=500

# ---- 运行模式 ----
# 模拟模式：true=模拟（不会真实下单），false=实盘
# ⚠️ 上线前务必先用 true 验证策略，确认无误后改为 false
DRY_RUN=true

# 轮询间隔（毫秒，5000=每5秒检查一次市场）
POLLING_INTERVAL=5000

# ---- 日志 ----
LOG_LEVEL=info
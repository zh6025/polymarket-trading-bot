# ============================================================
# Polymarket BTC 5m Trading Bot — Environment Configuration
# Copy this file to .env and fill in real values before running.
# ============================================================

# ── Polymarket API / Auth ────────────────────────────────────
# Your Polymarket CLOB API key.
# Obtain at: https://polymarket.com → Account Settings → API Keys
API_KEY=your_polymarket_api_key_here

# Your Ethereum wallet private key (hex, without 0x prefix).
# ⚠️  Never commit this file or share the private key.
PRIVATE_KEY=your_wallet_private_key_here

# Polymarket proxy wallet address (from your Polymarket account).
PROXY_ADDRESS=your_proxy_wallet_address_here

# CLOB endpoint (leave default unless Polymarket changes it).
CLOB_HOST=https://clob.polymarket.com

# Polygon chain ID (137 = mainnet, 80001 = Mumbai testnet).
CHAIN_ID=137

# ── Runtime ──────────────────────────────────────────────────
# true  = dry-run (log decisions but place NO real orders)
# false = live trading (real orders will be placed)
DRY_RUN=true

# Enable/disable the trading logic (true/false).
TRADING_ENABLED=true

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Path to the JSON state file used by bot_runner.py.
STATE_FILE_PATH=bot_state.json

# Path to the SQLite database used by bot_continuous.py.
DB_PATH=bot_data.db

# ── Order sizing ─────────────────────────────────────────────
# Minimum order size in USDC.
MIN_ORDER_SIZE=5.0

# Maximum total position size per direction in USDC.
MAX_POSITION_SIZE=500.0

# ── Risk management ──────────────────────────────────────────
# Stop new entries once daily realised loss exceeds this (USDC).
MAX_DAILY_LOSS=100.0
DAILY_LOSS_LIMIT_USDC=100.0

# Maximum number of trades per calendar day.
MAX_TRADES_PER_DAY=50
DAILY_TRADE_LIMIT=50

# Seconds to wait between trades on the same market (cooldown).
COOLDOWN_SECONDS=30

# Stop trading after this many consecutive losses.
CONSECUTIVE_LOSS_LIMIT=5

# ── Market polling ────────────────────────────────────────────
# How often the continuous bot polls the order book (seconds).
ORDERBOOK_POLL_SECONDS=5

# Legacy: polling interval in milliseconds (for backward compat).
POLLING_INTERVAL=5000

# ── Strategy tuning ──────────────────────────────────────────
# Take-profit and stop-loss thresholds (as a fraction of entry price).
PROFIT_TAKE_PCT=0.15
STOP_LOSS_PCT=0.10

# Order-book imbalance ratio required to trigger a trade signal.
IMBALANCE_THRESHOLD=0.65

# Minimum bid-ask spread to consider a book liquid.
MIN_SPREAD=0.02

# ── Entry timing ─────────────────────────────────────────────
# Do not open new entries within this many seconds of market expiry.
HARD_STOP_NEW_ENTRY_SEC=60

# Minimum elapsed seconds since the market opened for a main entry.
MIN_SECS_MAIN_ENTRY=10

# Minimum elapsed seconds since the market opened for a hedge entry.
MIN_SECS_HEDGE_ENTRY=10

# ── Main-leg price range ─────────────────────────────────────
# Only enter the main leg when the mid-price is in this range.
MIN_MAIN_PRICE=0.55
MAX_MAIN_PRICE=0.80

# ── Hedge-leg price range ────────────────────────────────────
MIN_HEDGE_PRICE=0.15
MAX_HEDGE_PRICE=0.45

# ── Spread / depth guards ────────────────────────────────────
# Reject books with a spread wider than these values.
MAX_MAIN_SPREAD=0.05
MAX_HEDGE_SPREAD=0.08

# Minimum depth (USDC) on the bid side required to enter.
MIN_MAIN_DEPTH_USDC=50.0
MIN_HEDGE_DEPTH_USDC=20.0

# ── Kelly / hedge sizing ─────────────────────────────────────
# Minimum implied win probability required to trade the main leg.
MIN_WIN_PROB=0.55

# Maximum hedge ratio (fraction of main size to allocate to hedge).
MAX_HEDGE_RATIO=0.70

# Below this ratio the hedge is skipped as not worth the fees.
MIN_MEANINGFUL_HEDGE_RATIO=0.05

# Only allow one open position per market at a time.
ONE_POSITION_PER_MARKET=true

# ── Legacy / grid settings (kept for backward compatibility) ─
LEVELS_EACH_SIDE=5
GRID_STEP=0.02
ORDER_SIZE=5.0
TRADE_BOTH_OUTCOMES=true

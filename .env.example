# ============================================================
# Polymarket Trading Bot — Full Configuration Reference
# Copy to .env and fill in real values
# ============================================================

# ---- Polymarket API ----
# Get from: https://polymarket.com → Account → API Keys
API_KEY=your_polymarket_api_key_here

# ---- Run mode ----
# DRY_RUN=true → simulate only, no real orders placed
DRY_RUN=true
# TRADING_ENABLED must be true for real order placement
TRADING_ENABLED=false

# ---- Strategy selection ----
# Options: imbalance | directional | momentum_hedge
STRATEGY=imbalance

# ---- Risk controls ----
DAILY_LOSS_LIMIT_USDC=20
DAILY_TRADE_LIMIT=20
CONSECUTIVE_LOSS_LIMIT=3
HARD_STOP_NEW_ENTRY_SEC=30
MIN_SECS_MAIN_ENTRY=90
MIN_SECS_HEDGE_ENTRY=60

# ---- Bet sizing ----
MAIN_BET_SIZE_USDC=3.0
MAIN_NOTIONAL=5.0
MAIN_MAX_PRICE=0.66

# ---- Hedge ----
ENABLE_HEDGE=false
HEDGE_NOTIONAL=1.0
HEDGE_MAX_PRICE=0.15
HEDGE_MAX_PRICE_DECISION=0.25
FIXED_HEDGE_RATIO=0.33
USE_DYNAMIC_RATIO=true

# ---- Imbalance strategy ----
DOMINANCE_THRESHOLD=0.68
MAX_SPREAD_PCT=0.05
ENTRY_DELAY_SECONDS=90
TRADE_WINDOW_END_SECONDS=270
CONFIRMATION_CHECKS=2
MIN_SAMPLES=5

# ---- Directional strategy (EMA+ATR) ----
EMA_FAST_PERIOD=3
EMA_SLOW_PERIOD=8
ATR_PERIOD=10
ATR_THRESHOLD_PCT=0.0003
MAX_ENTRY_PRICE=0.55
BET_SIZE=5
EMA_SIGNAL_BUFFER=0.0002

# ---- Momentum hedge strategy ----
TRIGGER_THRESHOLD=0.70
TOTAL_BET_SIZE=4.0
MAX_TRIGGER_PRICE=0.85
WIN_RATE_SLOPE=1.0

# ---- Polling ----
POLLING_INTERVAL=30000

# ---- Logging ----
LOG_LEVEL=info

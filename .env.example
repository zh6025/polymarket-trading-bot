# ============================================
# Polymarket Trading Bot - 完整配置说明
# 复制此文件为 .env 并填入真实值
# ============================================

# ---- Polymarket API ----
# 你的 Polymarket CLOB API Key
# 获取方式：登录 https://polymarket.com → 账户设置 → API Keys
API_KEY=your_polymarket_api_key_here

# ---- 策略配置 ----
# 交易市场 slug 现在由机器人动态计算（btc-updown-5m-<epoch时间戳>），无需手动配置
# SERIES_SLUG 已废弃，保留仅供参考
# SERIES_SLUG=btc-updown-5m-<timestamp>

# 网格每侧挂单层数（默认 5 层）
LEVELS_EACH_SIDE=5

# 网格步长，价格间距（默认 0.02 = 2%）
GRID_STEP=0.02

# 每笔订单大小（单位 USDC，默认 5）
ORDER_SIZE=5

# 是否同时交易 UP 和 DOWN 两个方向（true=双向）
TRADE_BOTH_OUTCOMES=true

# ---- 风控配置 ----
# 每日最大亏损上限（USDC，超过后停止交易）
DAILY_LOSS_LIMIT=100

# 最大持仓规模（USDC）
MAX_POSITION_SIZE=500

# ---- 运行模式 ----
# 模拟模式：true=模拟（不会真实下单），false=实盘
# ⚠️ 上线前务必先用 true 验证策略，确认无误后改为 false
DRY_RUN=true

# 轮询间隔（毫秒，5000=每5秒检查一次市场）
POLLING_INTERVAL=5000

# ---- 日志 ----
LOG_LEVEL=info

# ---- DirectionScorer 配置 ----
# 是否启用9维方向评分器（false=使用简单mid价格比率）
SCORER_ENABLED=true

# Sigmoid陡度参数 k（越大信号越敏感）
SCORER_STEEPNESS=3.0

# 概率超过此值 → BUY_YES
SCORER_BUY_THRESHOLD=0.58

# 概率低于此值 → BUY_NO
SCORER_SELL_THRESHOLD=0.42

# 最低置信度（低于此值不交易）
MIN_CONFIDENCE=0.15

# ---- 价格窗口过滤 ----
# 主仓位（YES/NO）允许价格区间
MAIN_PRICE_MIN=0.50
MAIN_PRICE_MAX=0.65

# 对冲仓位允许价格区间（便宜对冲最佳区间）
HEDGE_PRICE_MIN=0.05
HEDGE_PRICE_MAX=0.15

# ---- 执行顺序与费率 ----
# 先下对冲单再下主单（更安全，避免裸露仓位）
HEDGE_FIRST=true

# Polymarket 手续费率
FEE_RATE=0.02
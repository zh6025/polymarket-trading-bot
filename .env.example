# ===========================================================================
# Polymarket Trading Bot – Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ===========================================================================

# ---------------------------------------------------------------------------
# Safety gate (REQUIRED for live trading)
# ---------------------------------------------------------------------------
# Set to "live" to enable real order placement.
# Any other value (or leaving blank) activates DRY RUN mode.
TRADING_MODE=dry_run

# ---------------------------------------------------------------------------
# Polymarket / Ethereum credentials
# ---------------------------------------------------------------------------
# Your Ethereum private key (hex, with or without leading 0x).
# This key is used to sign CLOB orders.
PK=0xYOUR_PRIVATE_KEY_HERE

# Your Polymarket wallet address (the Ethereum EOA that owns your USDC).
# This is shown in your Polymarket profile URL and is pre-filled below.
# Format: 0x<40 hex chars>
# The Polymarket username format is: <address>-<nonce>  (only the address part goes here)
POLYMARKET_FUNDER_ADDRESS=0xe95ce742AfC2977965998810f326192D1593c1E1

# Polymarket CLOB API credentials
# Obtain these from the Polymarket UI (Settings → API Keys) or via L1 auth.
POLYMARKET_API_KEY=your_api_key_here
POLYMARKET_API_SECRET=your_api_secret_here
POLYMARKET_API_PASSPHRASE=your_api_passphrase_here

# Polygon chain ID (137 = mainnet, do not change unless testing)
CHAIN_ID=137

# ---------------------------------------------------------------------------
# Blockchain RPC
# ---------------------------------------------------------------------------
# Polygon RPC URL for reading Chainlink price feeds on-chain.
# Free public endpoint is provided as default but may be rate-limited.
# Consider using Alchemy (https://www.alchemy.com) or Infura.
WEB3_POLYGON_RPC=https://polygon-rpc.com

# ---------------------------------------------------------------------------
# Strategy parameters
# ---------------------------------------------------------------------------
# Per-trade USDC notional (default: 1.0)
MAX_TRADE_USDC=1.0

# Maximum daily loss in USDC before trading halts (default: 10.0)
DAILY_MAX_LOSS_USDC=10.0

# Minimum absolute price divergence between UP and DOWN asks to trigger entry
# (default: 0.10, i.e. 10 cents in $0..$1 price space)
DIVERGENCE_THRESHOLD=0.10

# Set to "true" to use relative (percentage) divergence instead of absolute
USE_RELATIVE_DIVERGENCE=false

# Minimum BTC price return magnitude to register a trend (default: 0.001 = 0.1%)
TREND_THRESHOLD_PCT=0.001

# Ask price below which an opportunistic buy is triggered (default: 0.20)
OPPORTUNITY_PRICE_MAX=0.20

# Mid price above which the opportunity position is sold for profit (default: 0.40)
TAKE_PROFIT_PRICE=0.40

# ---------------------------------------------------------------------------
# Exit behaviour
# ---------------------------------------------------------------------------
# When true (default), all open positions are sold in the final 60 seconds.
# When false, positions are held if the trend is still consistent.
FLATTEN_BEFORE_SETTLEMENT=true

# ---------------------------------------------------------------------------
# Daily reset timezone
# ---------------------------------------------------------------------------
# UTC offset in hours for the daily loss-counter reset.
# 0 = UTC (default), -5 = US Eastern Standard Time, 8 = China Standard Time
DAILY_RESET_TZ_OFFSET_HOURS=0

# ---------------------------------------------------------------------------
# Operational settings
# ---------------------------------------------------------------------------
# Main loop polling interval in seconds (default: 1.0)
LOOP_INTERVAL_SECS=1.0

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Path to the SQLite database file inside the container
DB_PATH=/data/trading_bot.db

# Optional: override the CLOB API base URL (for testing)
# CLOB_BASE_URL=https://clob.polymarket.com

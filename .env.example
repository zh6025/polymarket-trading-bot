# ============================================================
# Polymarket Trading Bot — 完整配置说明
# 复制此文件为 .env 并填入真实值
# ============================================================

# ---- CLOB 连接 ----
HOST=https://clob.polymarket.com
CHAIN_ID=137
# 你的钱包私钥（用于签名真实订单）
PRIVATE_KEY=your_private_key_here
# 代理合约地址（如有）
PROXY_ADDRESS=
# Polymarket API Key
API_KEY=your_polymarket_api_key_here

# ---- 运行模式 ----
# 模拟模式：true=不下真实订单（推荐先用这个验证）
DRY_RUN=true
# 实盘开关：必须设为 true 才能执行真实订单
TRADING_ENABLED=false

# ---- 状态持久化 ----
STATE_FILE_PATH=bot_state.json

# ---- 风控参数 ----
# 每日最大亏损（USDC），超出后停止交易
DAILY_LOSS_LIMIT_USDC=20
# 每日最大交易次数
DAILY_TRADE_LIMIT=20
# 最大连续亏损次数，达到后暂停
CONSECUTIVE_LOSS_LIMIT=3

# ---- 策略参数（动量对冲 + Kelly 仓位） ----
# 触发入场的最低概率阈值（0.70 = 70%）
MOMENTUM_THRESHOLD=0.70
# 假设的概率边际（用于 Kelly 计算）
EDGE_FACTOR=0.05
# Kelly 分数上限（防止过度押注）
KELLY_FRACTION_CAP=0.25
# 对冲比例（主仓的 30% 用于反向对冲）
HEDGE_RATIO=0.30
# 是否启用对冲
ENABLE_HEDGE=true
# 可用资金（USDC），Kelly 计算基准
BANKROLL=100.0

# ---- 订单大小限制 ----
MIN_ORDER_SIZE=3.0
MAX_ORDER_SIZE=50.0

# ---- 轮询间隔（秒） ----
POLLING_INTERVAL=10

# ---- 日志 ----
LOG_LEVEL=info

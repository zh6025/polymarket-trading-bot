# ============================================
# Polymarket BTC 5m Multi-Window Trading Bot
# Copy this file to .env and fill in real values
# ============================================

# ---- Polymarket API ----
# Your Polymarket CLOB API credentials
# Obtain at: https://polymarket.com → Account Settings → API Keys
API_KEY=your_polymarket_api_key_here
API_SECRET=your_polymarket_api_secret_here
API_PASSPHRASE=your_polymarket_api_passphrase_here

# ---- Safety Switches ----
# TRADING_ENABLED: 是否允许交易
#   true  → 允许交易 (trading allowed)
#   false → 观察模式，不下任何订单 (observation only, no orders)
TRADING_ENABLED=false

# DRY_RUN: 是否模拟交易
#   true  → 模拟交易，不发真实订单 (simulated, no real orders placed)
#   false → 真实交易，发真实订单！(REAL trading, real orders placed!)
# ⚠️ 要真实交易：TRADING_ENABLED=true 且 DRY_RUN=false
DRY_RUN=true

# ---- Window Feature Flags ----
# Window 0 (early momentum, ~260-275s remaining) — experimental, disabled by default
WINDOW0_ENABLED=false

# ---- Price Thresholds ----
# Hard cap: never buy a token priced above this (default 0.85)
HARD_CAP_PRICE=0.85

# Minimum price (confidence level) to enter in Window 0 (stricter, default 0.70)
MIN_CONFIDENCE_W0=0.70

# Minimum price (confidence level) to enter in Window 1 (default 0.55)
MIN_CONFIDENCE_W1=0.55

# Minimum price for late entry in Window 2 (default 0.65)
LATE_ENTRY_MIN_PRICE=0.65

# ---- Market Quality Filters ----
# Maximum allowed spread between best bid and ask (default 0.05 = 5%)
MAX_SPREAD=0.05

# Minimum combined bid+ask depth in USDC (default 50)
MIN_DEPTH=50

# ---- Bias Computation (BTC Momentum) ----
# Minimum 5-minute BTC price change to count as directional (default 0.0015 = 0.15%)
MOMENTUM_5M_THRESHOLD=0.0015

# Minimum 15-minute BTC price change to count as trend (default 0.003 = 0.30%)
MOMENTUM_15M_THRESHOLD=0.003

# ---- Volatility Safety ----
# If recent 10s price change exceeds this fraction, skip trading (default 0.20 = 20%)
MAX_RECENT_VOLATILITY=0.20

# ---- Bet Sizing (per-window) ----
# 每个窗口独立下注金额 (USDC)
# Window 0 (早期动量): 3 USDC
BET_SIZE_W0=3.0
# Window 1 (主入场): 5 USDC
BET_SIZE_W1=5.0
# Window 2 (晚期入场): 3 USDC
BET_SIZE_W2=3.0

# ---- Risk Controls ----
# Daily loss limit in USDC — triggers circuit breaker if exceeded (default 20)
DAILY_LOSS_LIMIT_USDC=20

# Maximum number of trades per day (default 20)
DAILY_TRADE_LIMIT=20

# Stop trading after this many consecutive losses (default 3)
CONSECUTIVE_LOSS_LIMIT=3

# ---- Polling ----
# Main loop polling interval in milliseconds (default 5000 = 5s, max 5000)
POLLING_INTERVAL=5000

# ---- Auto-Redeem ----
# 自动赎回已结算仓位，回收USDC (auto-redeem resolved positions)
# true  → 每次轮询自动检查并赎回 (auto-redeem on each poll)
# false → 不自动赎回，需手动操作 (manual redemption)
AUTO_REDEEM=true

# ---- Logging ----
LOG_LEVEL=INFO
# ── Polymarket Grid Bot — Configuration Template ──────────────────────────────
# Copy this file to .env and fill in your values.
# Lines starting with # are comments.
# Never commit your real .env to version control.

# ── Market ─────────────────────────────────────────────────────────────────────

# Specific event slug to trade.
# Leave blank to auto-discover the latest open event in SERIES_SLUG.
# Example: btc-updown-5m-1773753900
SLUG=

# Series slug used for auto-discovery.
SERIES_SLUG=btc-up-or-down-5m

# ── Grid Strategy ──────────────────────────────────────────────────────────────

# Number of grid levels on each side of the mid price.
LEVELS_EACH_SIDE=5

# Price step between levels. Must be a multiple of the market's tick_size.
# For BTC 5m markets the tick_size is typically 0.01.
GRID_STEP=0.02

# USDC order size per level. Must be >= the market's min_order_size (usually 5).
ORDER_SIZE=5

# Set to "false" to only trade the Up outcome.
TRADE_BOTH_OUTCOMES=true

# ── Bot Loop ───────────────────────────────────────────────────────────────────

# Polling interval in milliseconds.
INTERVAL_MS=5000

# Stop the bot after this many consecutive fetch errors.
MAX_ERRORS=5

# ── Risk Management ────────────────────────────────────────────────────────────

# Stop placing new orders if daily losses exceed this amount (USDC).
MAX_DAILY_LOSS_USDC=50

# Maximum total open position value (USDC).
MAX_POSITION_USDC=200

# ── Execution Mode ─────────────────────────────────────────────────────────────

# Set to "false" for live trading. "true" (default) prints orders without placing them.
DRY_RUN=true

# ── Authentication (required for live trading) ─────────────────────────────────

# Polymarket CLOB API key.
PM_API_KEY=

# Ethereum private key for signing orders (hex string, with or without 0x prefix).
# Keep this secret — never share or commit it.
PM_PRIVATE_KEY=

# Optional: Polymarket session cookie (used by some debug scripts).
PM_COOKIE=
